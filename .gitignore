# Python virtualenvs
.venv/
venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Test + lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artifacts
*.egg-info/
dist/
build/

# OS
.DS_Store

# Swift Package Manager build artifacts
# Package.swift is committed; .build/ is the SPM index/build cache (700M+) and
# Package.resolved gets regenerated by Xcode/SPM on open. Ignore both — the
# vendored libs/cua-driver/Sources/ is the true source of truth.
.build/
Package.resolved
*.xcodeproj/
.swiftpm/

# uv lockfile is intentionally COMMITTED for reproducibility — do not gitignore.
